{
  "name": "gaohong-student-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_TELEMETRY_DISABLED=1 NEXT_TEST_WASM_DIR=node_modules/@next/swc-wasm-nodejs next dev -p 3001 -H 127.0.0.1",
    "build": "NEXT_TELEMETRY_DISABLED=1 NEXT_TEST_WASM_DIR=node_modules/@next/swc-wasm-nodejs next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:generate:cloudflare": "prisma generate --schema prisma/schema.cloudflare.prisma",
    "db:push": "sqlite3 prisma/dev.db < prisma/init.sql",
    "db:seed": "tsx prisma/seed.ts",
    "db:init": "prisma generate && sqlite3 prisma/dev.db < prisma/init.sql && tsx prisma/seed.ts",
    "cf:build": "prisma generate && opennextjs-cloudflare build && node scripts/patch-prisma-binary.mjs",
    "cf:preview": "prisma generate && opennextjs-cloudflare build && node scripts/patch-prisma-binary.mjs && opennextjs-cloudflare preview",
    "cf:deploy": "prisma generate && opennextjs-cloudflare build && node scripts/patch-prisma-binary.mjs && opennextjs-cloudflare deploy",
    "cf:d1:init:local": "wrangler d1 execute gaohong-student-system-db --local --file prisma/init.sql",
    "cf:d1:init:remote": "wrangler d1 execute gaohong-student-system-db --remote --file prisma/init.sql",
    "cf:d1:seed:remote": "wrangler d1 execute gaohong-student-system-db --remote --file prisma/seed-cloudflare.sql"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "wrangler": "^4.87.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "^15.5.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
